{
  "name": "jie",
  "version": "1.0.0",
  "description": "杰 v1.0 - 极简托盘截图工具（区域截图 + 置顶钉图）",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {},
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.jie.v1",
    "productName": "杰 v1.0",
    "directories": {
      "output": "../jie-v1.0-test-package"
    },
    "files": [
      "main.js",
      "preload.js",
      "*.html",
      "*.js",
      "runninghub-workflows/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "icon": "assets/jie-icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "杰-v${version}-Portable.${ext}"
    }
  }
}
