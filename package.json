{
  "name": "running-jietu",
  "version": "2.0.0",
  "description": "Running Jietu v2.0 - 极简托盘截图工具（区域截图 + 置顶钉图）",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {},
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.ruADWnningjietu.v2",
    "productName": "Running Jietu v2.0",
    "directories": {
      "output": "../打包文件"
    },
    "files": [
      "main.js",
      "preload.js",
      "*.html",
      "*.js",
      "assets/**/*",
      "runninghub-workflows/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "electronDist": "node_modules/electron/dist",
    "win": {
      "icon": "assets/running-jietu-icon.png",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Running-Jietu-v${version}-Portable.${ext}"
    }
  }
}